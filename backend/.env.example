# Database
DATABASE_URL=postgresql://securefair:changeme@localhost:5432/securefair

# JWT — generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
CODE_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Ed25519 signing keys — generate with: python backend/generate_keys.py
SIGNING_PRIVATE_KEY=base64-encoded-ed25519-private-key
SIGNING_PUBLIC_KEY=base64-encoded-ed25519-public-key

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Enrollment Code Configuration
ENROLLMENT_CODE_EXPIRE_SECONDS=120
ENROLLMENT_CODE_LENGTH=6

# CORS — JSON array string of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://securefair:changeme@localhost:5432/securefair

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET_KEY=your-secret-key-generate-with-openssl-rand-hex-32
CODE_SECRET_KEY=your-code-secret-generate-with-openssl-rand-hex-32
ED25519_PRIVATE_KEY=generate-with-nacl-signing-key
ED25519_PUBLIC_KEY=generate-with-verify-key

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Enrollment Code Configuration
ENROLLMENT_CODE_EXPIRE_SECONDS=120
ENROLLMENT_CODE_LENGTH=6

# QR Token Configuration
QR_TOKEN_EXPIRE_HOURS=24

# Server Configuration
ENVIRONMENT=development
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Email (for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
